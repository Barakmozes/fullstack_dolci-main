# MongoDB Atlas credentials (used to construct connection URI)
DB_USER=<mongodb-atlas-username>
DB_PASS=<mongodb-atlas-password>

# JWT signing secret (make it long and random, min 32 characters)
TOKEN_SECRET=<min-32-char-random-secret>

# OR use a single connection string (overrides DB_USER/DB_PASS):
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/dolci

# Server port (defaults to 5000)
# PORT=5000
